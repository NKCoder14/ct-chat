<?xml version="1.0" encoding="utf-8"?>

                                                       
                                                   

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_color"
        tools:context=".activities.ChatActivity" android:tag="layout/activity_chat_0" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools">

        <!-- Modern toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/toolbar_background"
            android:elevation="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:titleTextColor="@color/toolbar_title_color"
            app:navigationIconTint="@color/toolbar_icon_color" />

        <!-- Divider below toolbar -->
        <View
            android:id="@+id/toolbarDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color"
            app:layout_constraintTop_toBottomOf="@id/toolbar" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chatRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:padding="12dp"
            android:clipToPadding="false"
            android:background="@color/surface_color"
            app:layout_constraintTop_toBottomOf="@id/toolbarDivider"
            app:layout_constraintBottom_toTopOf="@id/messageInputContainer" />

        <!-- Modern message input bar -->
        <LinearLayout
            android:id="@+id/messageInputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="@color/background_color"
            app:layout_constraintBottom_toBottomOf="parent">

            <EditText
                android:id="@+id/messageBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="44dp"
                android:background="@drawable/message_input_background"
                android:hint="Type a message..."
                android:textColorHint="@color/on_surface_variant"
                android:textColor="@color/on_surface_color"
                android:textSize="15sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:maxLines="4"
                android:scrollbars="vertical" />

            <ImageView
                android:id="@+id/btnSend"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:padding="10dp"
                android:background="@drawable/send_button_background"
                android:src="@android:drawable/ic_menu_send"
                android:contentDescription="Send"
                app:tint="@color/on_primary_color" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
         