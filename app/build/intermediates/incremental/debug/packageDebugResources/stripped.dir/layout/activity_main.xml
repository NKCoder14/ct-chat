<?xml version="1.0" encoding="utf-8"?>

                                                       
                                                   

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_color"
        tools:context=".activities.MainActivity" android:tag="layout/activity_main_0" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools">

        <!-- Toolbar with title and 3-dot menu -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/toolbar_background"
            android:elevation="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:popupTheme="@style/Theme.CTChat.PopupOverlay"
            app:titleTextColor="@color/toolbar_title_color"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge" />

        <!-- Search bar below toolbar -->
        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/search_bar_background"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:drawableTint="@color/search_bar_hint"
            android:hint="Search..."
            android:textColorHint="@color/search_bar_hint"
            android:textColor="@color/on_surface_color"
            android:textSize="15sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="text"
            android:maxLines="1"
            android:imeOptions="actionSearch"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Divider below search bar -->
        <View
            android:id="@+id/toolbarDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color"
            app:layout_constraintTop_toBottomOf="@id/etSearch"
            android:layout_marginTop="8dp" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/toolbar_background"
            android:elevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/toolbarDivider"
            app:tabIndicatorColor="@color/tab_indicator_color"
            app:tabIndicatorHeight="3dp"
            app:tabIndicatorFullWidth="false"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabRippleColor="@color/ripple_color"
            app:tabSelectedTextColor="@color/tab_selected_text_color"
            app:tabTextColor="@color/tab_text_color"
            app:tabTextAppearance="@style/TextAppearance.Material3.LabelLarge" />

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@color/surface_color"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tabLayout" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabNewGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:contentDescription="Create New Group"
            app:srcCompat="@drawable/ic_new_group"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:backgroundTint="@color/primary_color"
            app:tint="@color/on_primary_color"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.CTChat.MediumComponent"
            app:fabSize="normal"
            app:elevation="6dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
         