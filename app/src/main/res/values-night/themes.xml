<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Dark Material 3 Theme -->
    <style name="Theme.CTChat" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorPrimaryVariant">@color/primary_dark_color</item>
        <item name="colorOnPrimary">@color/on_primary_color</item>
        <item name="colorPrimaryContainer">@color/primary_light_color</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary_color</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Surface colors -->
        <item name="colorSurface">@color/surface_color</item>
        <item name="colorOnSurface">@color/on_surface_color</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Dark status bar with light icons -->
        <item name="android:statusBarColor">@color/status_bar_color</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:navigationBarColor">@color/navigation_bar_color</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <!-- Outline -->
        <item name="colorOutline">@color/outline_color</item>

        <!-- Shape overrides for rounded corners -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.CTChat.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.CTChat.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.CTChat.LargeComponent</item>

        <!-- Default button style -->
        <item name="materialButtonStyle">@style/Widget.CTChat.Button</item>
    </style>

    <!-- Dark AppBar overlays -->
    <style name="Theme.CTChat.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar" />
    <style name="Theme.CTChat.PopupOverlay" parent="ThemeOverlay.Material3.Dark" />
</resources>